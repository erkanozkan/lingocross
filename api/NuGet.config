<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Bu proje yalnızca herkese açık nuget.org kaynağını kullanır.
       Kurumsal Nexus (nexus.pttavm.com) VPN gerektirdiği ve burada
       gerekmediği için bilinçli olarak devre dışı bırakılmıştır. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
